# Database Configuration
DATABASE_URL=postgresql+psycopg://localhost:5432/scopewise

# Application Configuration
APP_NAME=ScopeWise
DEBUG=false

# Authentication Configuration
JWT_SECRET_KEY=your-secret-key-here-at-least-32-characters-long
TOKEN_EXPIRY_HOURS=24

# Environment Configuration
ENV=local

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# OpenRouter Configuration (LLM + Embeddings - all AI via one provider)
# OpenRouter provides access to OpenAI models including GPT-4 and text-embedding-3-small
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4
OPENROUTER_TEMPERATURE=0.0

# Tavily Configuration (for market research web search)
TAVILY_API_KEY=your-tavily-api-key

# ChromaDB Configuration (for RAG vector store)
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=firm_projects

# Logging
LOG_LEVEL=INFO
